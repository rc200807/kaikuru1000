generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ライセンスキー（本部が事前登録）
model LicenseKey {
  id        String   @id @default(cuid())
  key       String   @unique
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?
}

// 顧客ユーザー
model User {
  id             String    @id @default(cuid())
  name           String
  furigana       String
  email          String    @unique
  phone          String
  address        String
  password       String
  licenseKeyId   String    @unique
  licenseKey     LicenseKey @relation(fields: [licenseKeyId], references: [id])
  idDocumentPath  String?   @db.Text  // 身分証明書ファイルURL（Vercel Blob）
  // 身分証OCR抽出フィールド（Gemini Vision）
  idDocumentType  String?             // 書類種別（運転免許証/パスポート/マイナンバーカードなど）
  idName          String?             // 身分証記載氏名
  idBirthDate     String?             // 生年月日（YYYY-MM-DD または 和暦テキスト）
  idAddress       String?   @db.Text  // 身分証記載住所
  idLicenseNumber String?             // 免許番号・旅券番号など
  idExpiryDate    String?             // 有効期限（YYYY-MM-DD または テキスト）
  idOcrIssueReport String?  @db.Text  // 顧客によるOCR誤り報告
  storeId        String?   // 担当店舗ID（本部が割り当て）
  store          Store?    @relation(fields: [storeId], references: [id])
  isTestData     Boolean   @default(false)
  isActive       Boolean   @default(true)
  visitSchedules VisitSchedule[]
  purchaseMemos  PurchaseMemo[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 店舗
model Store {
  id         String   @id @default(cuid())
  name       String   // 店舗名
  code       String   @unique // 店舗コード
  phone      String?
  address    String?
  prefecture String?  // 都道府県
  email      String?
  password   String
  avatar     String?  @db.Text  // プロフィール画像URL（Vercel Blob）
  sheetRowId String?  // Googleスプレッドシートの行ID（同期用）
  isActive   Boolean  @default(true)
  customers  User[]
  visitSchedules VisitSchedule[]
  members    StoreMember[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 店舗メンバー（店舗のサブアカウント）
model StoreMember {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  email     String   @unique
  password  String
  avatar    String?  @db.Text  // プロフィール画像URL（Vercel Blob）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 訪問スケジュール
model VisitSchedule {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  visitDate      DateTime
  status         String   @default("scheduled") // scheduled, completed, cancelled
  note           String?
  purchaseAmount Int?     // 買取金額（円）
  billingAmount  Int?     // 請求金額（円）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 管理者
model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // admin, superadmin
  avatar    String?  @db.Text  // プロフィール画像URL（Vercel Blob）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Googleスプレッドシート同期ログ
model SyncLog {
  id       String   @id @default(cuid())
  type     String   // stores, licenses
  status   String   // success, error
  message  String?  @db.Text
  syncedAt DateTime @default(now())
}

// メール送信設定（SMTP）
model EmailConfig {
  id          String   @id @default(cuid())
  smtpHost    String   @default("")
  smtpPort    Int      @default(587)
  smtpUser    String   @default("")
  smtpPass    String   @default("") @db.Text  // AES-256-GCM 暗号化済み
  fromAddress String   @default("")
  fromName    String   @default("買いクル 本部")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Google Sheets 連携設定（OAuth2トークン + スプレッドシート設定）
model GoogleSheetsConfig {
  id                  String    @id @default(cuid())
  googleEmail         String?
  accessToken         String?   @db.Text  // AES-256-GCM 暗号化済み（長いため Text 型）
  refreshToken        String?   @db.Text  // AES-256-GCM 暗号化済み
  tokenExpiry         DateTime?
  spreadsheetId       String?             // ライセンスキー用スプレッドシートID
  sheetName           String    @default("ライセンスキー")
  keyColumn           String    @default("A")
  storeSpreadsheetId  String?             // 店舗マスター用スプレッドシートID
  storeSheetName      String    @default("店舗マスター")
  storeColumnMapping  String?   @db.Text  // JSON: {"code":"A","name":"B",...}
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 買取相談メモ（顧客が買取希望品を事前に登録）
model PurchaseMemo {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String                      // 品名・タイトル
  description String?  @db.Text           // 詳細説明
  imageUrls   String   @default("[]") @db.Text  // JSON配列: 画像URL[]
  status      String   @default("pending") // pending, reviewed, completed
  storeNote   String?  @db.Text           // 店舗からのコメント
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ログイン試行回数制限（DB実装: サーバーレス対応）
model LoginAttempt {
  id           String    @id @default(cuid())
  key          String    @unique  // "role:email"
  failCount    Int       @default(0)
  firstFailAt  DateTime  @default(now())
  blockedUntil DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([key])
}
