generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ライセンスキー（本部が事前登録）
model LicenseKey {
  id        String   @id @default(cuid())
  key       String   @unique
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?
}

// 顧客ユーザー
model User {
  id             String    @id @default(cuid())
  name           String
  furigana       String
  email          String    @unique
  phone          String
  address        String
  password       String
  licenseKeyId   String?   @unique
  licenseKey     LicenseKey? @relation(fields: [licenseKeyId], references: [id])
  idDocumentPath  String?   @db.Text  // 身分証明書ファイルURL（Vercel Blob）
  // 身分証OCR抽出フィールド（Gemini Vision）
  idDocumentType  String?             // 書類種別（運転免許証/パスポート/マイナンバーカードなど）
  idName          String?             // 身分証記載氏名
  idBirthDate     String?             // 生年月日（YYYY-MM-DD または 和暦テキスト）
  idAddress       String?   @db.Text  // 身分証記載住所
  idLicenseNumber String?             // 免許番号・旅券番号など
  idExpiryDate    String?             // 有効期限（YYYY-MM-DD または テキスト）
  idOcrIssueReport String?  @db.Text  // 顧客によるOCR誤り報告
  storeId        String?   // 担当店舗ID（本部が割り当て）
  store          Store?    @relation(fields: [storeId], references: [id])
  isTestData     Boolean   @default(false)
  isActive       Boolean   @default(true)
  // 顧客タイプ
  customerType   String    @default("visit")  // "visit" | "delivery" | "regular"
  // 振込先口座情報
  bankName       String?
  branchName     String?
  accountType    String?   // "普通" | "当座"
  accountNumber  String?
  accountHolder  String?
  visitSchedules VisitSchedule[]
  purchaseMemos     PurchaseMemo[]
  deliveryShipments DeliveryShipment[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// 店舗
model Store {
  id         String   @id @default(cuid())
  name       String   // 店舗名
  code       String   @unique // 店舗コード
  phone      String?
  address    String?
  prefecture String?  // 都道府県
  email      String?
  password   String
  avatar     String?  @db.Text  // プロフィール画像URL（Vercel Blob）
  sheetRowId String?  // Googleスプレッドシートの行ID（同期用）
  isActive   Boolean  @default(true)
  customers  User[]
  visitSchedules VisitSchedule[]
  members    StoreMember[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 店舗メンバー（店舗のサブアカウント）
model StoreMember {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  email     String   @unique
  password  String
  avatar    String?  @db.Text  // プロフィール画像URL（Vercel Blob）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 訪問スケジュール
model VisitSchedule {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  visitDate      DateTime
  status         String   @default("scheduled") // scheduled, completed, cancelled
  note           String?
  purchaseAmount Int?     // 買取金額（円）— 品目合計から自動計算
  billingAmount  Int?     // 請求金額（円）— 作業品目合計から自動計算
  purchaseItems  PurchaseItem[]
  workItems      WorkItem[]
  salesContract  SalesContract?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 買取品目（訪問ごとに記録する買取商品）
model PurchaseItem {
  id              String        @id @default(cuid())
  visitScheduleId String
  visitSchedule   VisitSchedule @relation(fields: [visitScheduleId], references: [id], onDelete: Cascade)
  itemName        String                      // 品名
  category        String                      // カテゴリー
  imageUrls       String   @default("[]")   // JSON配列: 画像URL[] (最大3枚)
  quantity        Int      @default(1)        // 数量
  purchasePrice   Int      @default(0)        // 買取金額（円）
  aiResearch      String?                     // AI市場調査結果 (JSON文字列)
  aiResearchedAt  DateTime?                   // AI調査実行日時
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([visitScheduleId])
}

// 作業品目（訪問ごとの請求作業）
model WorkItem {
  id              String        @id @default(cuid())
  visitScheduleId String
  visitSchedule   VisitSchedule @relation(fields: [visitScheduleId], references: [id], onDelete: Cascade)
  workName        String                      // 作業名
  unitPrice       Int      @default(0)        // 単価（円）
  quantity        Int      @default(1)        // 数量
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([visitScheduleId])
}

// 管理者
model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin") // admin, superadmin
  avatar    String?  @db.Text  // プロフィール画像URL（Vercel Blob）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Googleスプレッドシート同期ログ
model SyncLog {
  id       String   @id @default(cuid())
  type     String   // stores, licenses
  status   String   // success, error
  message  String?  
  syncedAt DateTime @default(now())
}

// メール送信設定（SMTP）
model EmailConfig {
  id          String   @id @default(cuid())
  smtpHost    String   @default("")
  smtpPort    Int      @default(587)
  smtpUser    String   @default("")
  smtpPass    String   @default("")   // AES-256-GCM 暗号化済み
  fromAddress String   @default("")
  fromName    String   @default("買いクル 本部")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Google Sheets 連携設定（OAuth2トークン + スプレッドシート設定）
model GoogleSheetsConfig {
  id                  String    @id @default(cuid())
  googleEmail         String?
  accessToken         String?     // AES-256-GCM 暗号化済み（長いため Text 型）
  refreshToken        String?     // AES-256-GCM 暗号化済み
  tokenExpiry         DateTime?
  spreadsheetId       String?             // ライセンスキー用スプレッドシートID
  sheetName           String    @default("ライセンスキー")
  keyColumn           String    @default("A")
  storeSpreadsheetId  String?             // 店舗マスター用スプレッドシートID
  storeSheetName      String    @default("店舗マスター")
  storeColumnMapping  String?     // JSON: {"code":"A","name":"B",...}
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 買取相談メモ（顧客が買取希望品を事前に登録）
model PurchaseMemo {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String                      // 品名・タイトル
  description String?             // 詳細説明
  imageUrls   String   @default("[]")   // JSON配列: 画像URL[]
  status      String   @default("pending") // pending, reviewed, completed
  storeNote   String?             // 店舗からのコメント
  aiAppraisal   String?  @db.Text  // AI査定結果(JSON)
  aiAppraisalAt DateTime?           // AI査定実行日時
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 宅配買取送付履歴
model DeliveryShipment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipmentNumber String   @unique  // "HD-YYYYMM-NNNN"
  shipmentMonth  String            // "YYYY-MM"
  description    String?  
  imageUrls      String   @default("[]") 
  purchaseAmount Int?     // 査定金額（店舗が更新）
  status         String   @default("registered") // registered|shipped|received|appraised
  storeNote      String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([shipmentMonth])
}

// 売買契約書（署名・PDF保存）
model SalesContract {
  id              String        @id @default(cuid())
  visitScheduleId String        @unique
  visitSchedule   VisitSchedule @relation(fields: [visitScheduleId], references: [id], onDelete: Cascade)
  signatureData   String        // base64 PNG data URL（顧客署名）
  pdfBase64       String?       // base64 PDF データ
  customerEmail   String?       // 送信先メールアドレス（記録用）
  emailSentAt     DateTime?     // メール送信日時
  agreedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ログイン試行回数制限（DB実装: サーバーレス対応）
model LoginAttempt {
  id           String    @id @default(cuid())
  key          String    @unique  // "role:email"
  failCount    Int       @default(0)
  firstFailAt  DateTime  @default(now())
  blockedUntil DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([key])
}

// iPhone中古相場価格（Gemini AIによる月次取得）
model PhoneMarketPrice {
  id        String   @id @default(cuid())
  model     String   // "iPhone 15 Pro"
  series    String   // "iPhone 15"
  storage   String   // "128GB"
  gradeA    Int?     // A評価（美品）の相場（円）
  gradeB    Int?     // B評価（並品）の相場（円）
  gradeC    Int?     // C評価（難あり）の相場（円）
  source    String   @default("gemini")
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([model, storage])
  @@index([series])
}
